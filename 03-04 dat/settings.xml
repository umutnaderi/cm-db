<?xml version="1.0" encoding="UTF-8"?><!DOCTYPE propertylist SYSTEM "http://www.sigames.com/dtds/propertylist.dtd"><properties version="1.0">	<colour id="selc" name="yellow" comment="text colour for a selected item (eg the selected tab)"/>	<colour id="hilc" red="128" green="128" blue="180" comment="hilight colour for hilighted text / hilighted rows in tables, etc"/>		<integer id="dcht" value="20" comment="default control height"/>	<integer id="dcwd" value="128" comment="default control width"/>		<integer id="mvth" value="2" comment="movement threshold"/>	<integer id="hvtm" value="1000" comment="hover time"/>	<integer id="sdin" value="1" comment="still down initial time"/>	<integer id="sdiv" value="1" comment="still down interval time"/>	<integer id="dctm" value="500" comment="double click time"/>	<integer id="bltm" value="500" comment="cursor blink time"/>	<integer id="rptm" value="500" comment="repeat time"/>	<integer id="rpin" value="100" comment="repeat interval"/>	<integer id="scin" value="100" comment="scrolling interval"/>	<integer id="txfn" value="6" comment="text font"/>	<integer id="txst" value="0" comment="text style"/>	<integer id="txss" value="9" comment="text size small"/>	<integer id="txsn" value="10" comment="text size normal"/>	<integer id="txsl" value="12" comment="text size large"/>	<colour id="txcl" name="black" comment="text colour"/>	<integer id="hnfn" value="4" comment="hint font"/>	<integer id="hnst" value="0" comment="hint style"/>	<integer id="hnss" value="7" comment="hint size small"/>	<colour id="hncl" name="black" comment="hint colour"/>	<integer id="cnfn" value="6" comment="control font"/>	<integer id="cnst" value="0" comment="control style"/>	<integer id="cnss" value="7" comment="control size small"/>	<integer id="cnsn" value="9" comment="control size normal"/>	<integer id="cnsl" value="10" comment="control size large"/>	<colour id="cncl" name="black" comment="control colour"/>	<integer id="mnfn" value="6" comment="menu font"/>	<integer id="mnst" value="0" comment="menu style"/>	<integer id="mnss" value="9" comment="menu size small"/>	<integer id="mnsn" value="10" comment="menu size normal"/>	<integer id="mnsl" value="12" comment="menu size large"/>	<colour id="mncl" name="black" comment="menu colour"/>	<colour id="mnsc" name="yellow" comment="menu selected colour"/>	<integer id="mnop" value="500" comment="menu opacity"/>	<integer id="tlfn" value="6" comment="title font"/>	<integer id="tlst" value="128" comment="title style"/>	<integer id="tlss" value="22" comment="title size small"/>	<integer id="tlsn" value="18" comment="title size normal"/>	<integer id="tlsl" value="12" comment="title size large"/>	<colour id="tlcl" name="white" comment="title colour"/>	<colour id="dscl" red="160" green="160" blue="160" comment="disabled text colour"/>	<integer id="dsst" value="64" comment="disabled text style"/>		<true id="usep" comment="use background picture"/>	<colour id="bgcl" name="white" comment="background colour"/>	<real id="bgop" value="0.7" comment="background opacity"/>		<string id="date" comment="date format">	 [%date#1-day]<return/>[%date#1-short]<return/>[%date#1-time]	</string>	<integer id="cmod" value="0" comment="colour mode"/></properties>